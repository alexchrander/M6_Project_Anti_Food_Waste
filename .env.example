# ── Required ───────────────────────────────────────────────────────────────────
# Bearer token for the Salling Group Food Waste API
ANTI_FOOD_WASTE_API=your_api_token_here

# ── Optional overrides ─────────────────────────────────────────────────────────
# Defaults are already set in docker-compose.yml and config.py.
# Only uncomment and change these if you want different values.
# DB_NAME=food_waste
# DB_USER=food_waste_user
# DB_PASSWORD=food_waste_alex
# MYSQL_ROOT_PASSWORD=rootpassword
